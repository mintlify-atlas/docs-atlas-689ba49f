  "keyFeatures": [
    "Zero heap allocations during parsing",
    "Unboxed types (int16#, int64#, char#) for performance",
    "Stack-allocated results using unboxed records",
    "HTTP/1.1 support with chunked encoding, ETags, range requests",
    "RFC 7230 security compliance and request smuggling prevention",
    "Direct bigstring I/O for zero-copy operations",
    "Async-based static file server included"
  ],
  "publicApiSurface": [
    "Httpz.parse - Parse HTTP/1.1 requests with zero allocations",
    "Httpz.create_buffer - Create 32KB parsing buffer",
    "Req - Request type with method, target, headers, body info",
    "Res - Response writing functions for status, headers, chunked encoding",
    "Parser - Low-level parser combinators",
    "Header - Header name/value types",
    "Method - HTTP method enumeration (GET, POST, etc)",
    "Chunk - Chunked transfer encoding parser",
    "Etag - ETag parsing and comparison per RFC 7232",
    "Range - Range request parsing and Content-Range writing per RFC 7233",
    "Date - HTTP date formatting",
    "Span - Offset+length references into buffers",
    "Buf_read - Buffer reading utilities and status codes",
    "Buf_write - Buffer writing utilities"
  ]
}
